{
  "name": "smarttap",
  "version": "0.1.0",
  "private": true,
  "description": "SmartTap — Loyalty and reviews for Dublin local businesses",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.18.0 <21",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/node": "20.17.10",
    "eslint": "9.17.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "turbo": "2.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.19.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.18",
      "@types/react-dom": "18.3.5"
    }
  }
}
