# SmartTap backend env vars.
# Copy to `.env` for local dev. In production, set these in the Railway
# project dashboard (never commit a populated .env).
#
# ALL vars below have a Field() default in app/config.py — if you forget
# to set one, the app will still boot but the related feature will be
# disabled (e.g. empty RESEND_API_KEY → emails silently skip).

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# Tag the deployment so logs and Sentry can filter by env.
APP_ENV=development

# DEBUG / INFO / WARNING / ERROR. INFO is the right prod default.
LOG_LEVEL=INFO

# Comma-separated origins allowed to call the API from a browser.
# Prod must include the apex + www redirect target:
#   CORS_ORIGINS=https://smarttap.ie,https://www.smarttap.ie
CORS_ORIGINS=http://localhost:3000,https://smarttap.ie

# Public origin used to build links inside transactional emails. Must NOT
# have a trailing slash. Same value as NEXT_PUBLIC_SITE_URL on the frontend.
SITE_URL=https://smarttap.ie

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Project URL + the three keys, all from Supabase Dashboard → Settings → API.
# JWT_SECRET is only needed if you're using HS256 tokens — current setup
# uses ES256 via JWKS, so this can stay empty.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------

# Secret key — `sk_test_…` in dev, `sk_live_…` in prod. NEVER commit either.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — get it AFTER registering the endpoint in Stripe
# Dashboard. Different per env (test vs live). Leaving empty disables
# webhook verification, which causes /v1/webhooks/stripe to 400 every call.
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring monthly prices (one per plan). Live mode IDs differ from test
# mode IDs — make sure they match the STRIPE_SECRET_KEY's mode.
STRIPE_PRICE_REVIEW=price_...
STRIPE_PRICE_LOYALTY=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_NETWORK=price_...

# One-time setup fees, added to the first invoice on checkout.
STRIPE_PRICE_REVIEW_SETUP=price_...
STRIPE_PRICE_LOYALTY_SETUP=price_...
STRIPE_PRICE_PRO_SETUP=price_...
STRIPE_PRICE_NETWORK_SETUP=price_...

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------

# Empty key = code paths run but skip the actual send (dev-friendly).
# In prod, the smarttap.ie domain must be verified in Resend first or
# every send will land in spam / be rejected outright.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@smarttap.ie

# ---------------------------------------------------------------------------
# Cron (external scheduler — cron-job.org calls these endpoints)
# ---------------------------------------------------------------------------

# Shared secret the scheduler sends as `X-Cron-Token`. Empty = cron
# endpoints return 503 (safe fallback — no anonymous trigger).
# Generate a fresh value per env: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
CRON_TOKEN=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Empty = Sentry not initialized (no events sent). Set the backend DSN in prod.
SENTRY_DSN=
