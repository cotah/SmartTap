{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@/*": ["./src/*"],
      "@smarttap/core": ["../../packages/core/src/index.ts"],
      "@smarttap/core/*": ["../../packages/core/src/*"],
      "@smarttap/api": ["../../packages/api/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
