# SmartTap web env vars.
# Copy to `.env.local` for local dev. In production, set these in the
# Vercel project dashboard (Settings → Environment Variables). Never
# commit a populated env file.
#
# Two scopes:
#   NEXT_PUBLIC_*  → bundled into the client JS, visible in the browser.
#                    Anything here is effectively public.
#   (no prefix)    → server-side only (Server Components, Server Actions,
#                    Route Handlers). Never reaches the client.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Project URL + anon key, from Supabase Dashboard → Settings → API.
# anon key is safe in the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# service_role key is server-only. Bypasses RLS — never expose to the
# browser. Used by Server Actions that need privileged DB access.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------------------------------------------------------------------
# API + site URLs
# ---------------------------------------------------------------------------

# Where the FastAPI backend lives. Local: http://localhost:8000.
# Prod: https://api.smarttap.ie.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public origin of the frontend itself. Used to build absolute URLs in
# emails, OG tags, redirects. Must NOT have a trailing slash.
# Prod: https://smarttap.ie.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------

# Sprint 5.6 — shows the "Already a member?" SMS recovery block on /t/[uuid].
# Only set to "true" once the backend has Twilio configured (TWILIO_* vars)
# and migration 012_customer_otp_codes.sql is applied. Anything else hides it.
NEXT_PUBLIC_OTP_ENABLED=false

# ---------------------------------------------------------------------------
# PostHog (product analytics — optional)
# ---------------------------------------------------------------------------

# Leave empty in dev to disable. EU host keeps data in-region (GDPR).
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------

# Frontend project DSN — different from the backend DSN. Empty = disabled.
SENTRY_DSN=

# Auth token used by `sentry-cli` to upload sourcemaps during build.
# Only needed for prod builds with releases enabled.
SENTRY_AUTH_TOKEN=
