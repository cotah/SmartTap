{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@smarttap/core": ["../../packages/core/src/index.ts"],
      "@smarttap/core/*": ["../../packages/core/src/*"],
      "@smarttap/api": ["../../packages/api/src/index.ts"],
      "@smarttap/ui": ["../../packages/ui/src/index.ts"],
      "@smarttap/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
